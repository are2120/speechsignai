{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "login.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "register.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "dashboard.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "recordings.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "recordings-create.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "recordings-show.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "sign-language.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "conversation.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "profile.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "logout.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
